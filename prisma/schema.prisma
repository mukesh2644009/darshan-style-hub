// Production Prisma schema - PostgreSQL
// To use: Replace schema.prisma with this file and run migrations

generator client {
  provider        = "prisma-client-js"
  // `native` = local dev; `rhel-openssl-3.0.x` = Vercel Node 18+ Linux — avoids shipping every OS engine.
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model for authentication
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  password      String    // bcrypt-hashed; for Google-only users we store a random unguessable hash
  role          String    @default("CUSTOMER") // ADMIN or CUSTOMER

  // Google OAuth fields (null for users that signed up with email or phone)
  googleId      String?   @unique
  image         String?

  // Loyalty program
  loyaltyPoints Int       @default(0)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  addresses     Address[]
  orders        Order[]
  cartItems     CartItem[]
  wishlist      WishlistItem[]
  sessions      Session[]
  returnRequests ReturnRequest[]
  loyaltyTransactions LoyaltyTransaction[]

  @@index([email])
}

// Loyalty points ledger
model LoyaltyTransaction {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  points      Int       // positive = earn, negative = redeem
  type        String    // EARN_ORDER | REDEEM | BONUS | REFUND
  description String
  orderId     String?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Address model for shipping
model Address {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  phone         String
  addressLine1  String
  addressLine2  String?
  city          String
  state         String
  pincode       String
  isDefault     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
}

// Product model
model Product {
  id            String    @id @default(cuid())
  sku           String    @unique
  slug          String?   @unique  // SEO-friendly URL: green-embroidered-cotton-suit-set
  name          String
  description   String
  price         Float
  originalPrice Float?
  category      String
  subcategory   String
  inStock       Boolean   @default(true)
  featured      Boolean   @default(false)
  newArrival    Boolean   @default(false)
  rating        Float     @default(0)
  reviews       Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  images        ProductImage[]
  sizes         ProductSize[]
  colors        ProductColor[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]

  @@index([category])
  @@index([subcategory])
  @@index([featured])
}

// Product images
model ProductImage {
  id          String    @id @default(cuid())
  url         String
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// Product sizes with quantity
model ProductSize {
  id          String    @id @default(cuid())
  size        String
  quantity    Int       @default(0)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// Product colors
model ProductColor {
  id          String    @id @default(cuid())
  name        String
  hex         String
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// Cart items
model CartItem {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity      Int       @default(1)
  selectedSize  String
  selectedColor String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, productId, selectedSize, selectedColor])
  @@index([userId])
}

// Wishlist items
model WishlistItem {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// Order model
model Order {
  id              String      @id @default(cuid())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  status          String      @default("PENDING")
  paymentMethod   String      @default("COD")
  paymentStatus   String      @default("PENDING")
  razorpayPaymentId String?   // Razorpay payment_id after successful UPI/card pay
  razorpayRefundId  String?   // Last Razorpay refund id (audit)
  subtotal        Float
  shipping        Float       @default(0)
  discount        Float       @default(0)
  total           Float

  // Order classification — STANDARD (paid) or REPLACEMENT (₹0 exchange replacement)
  orderType       String      @default("STANDARD")
  // For REPLACEMENT orders, points back to the original paid order
  parentOrderId   String?
  parentOrder     Order?      @relation("OrderReplacements", fields: [parentOrderId], references: [id], onDelete: SetNull)
  replacements    Order[]     @relation("OrderReplacements")
  
  // Shipping details
  shippingName    String
  shippingPhone   String
  shippingAddress String
  shippingCity    String
  shippingState   String
  shippingPincode String

  // NimbusPost (or other aggregator) shipping metadata
  shippingPartner     String?
  shipmentId          String?
  awbNumber           String?
  courierName         String?
  trackingUrl         String?
  labelUrl            String?
  pickupScheduledAt   DateTime?
  shippedAt           DateTime?
  deliveredAt         DateTime?
  nimbusStatus        String?
  nimbusStatusCode    String?
  nimbusWebhookPayload Json?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  items           OrderItem[]
  returnRequest   ReturnRequest?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([parentOrderId])
  @@index([awbNumber])
  @@index([shipmentId])
  @@index([shippingPartner])
}

// Order items
model OrderItem {
  id            String    @id @default(cuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  quantity      Int
  price         Float
  size          String?
  color         String?

  @@index([orderId])
}

// Category model
model Category {
  id            String    @id @default(cuid())
  name          String    @unique
  createdAt     DateTime  @default(now())
  
  subcategories Subcategory[]
}

// Subcategory model
model Subcategory {
  id          String    @id @default(cuid())
  name        String
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([name, categoryId])
  @@index([categoryId])
}

// Session model for authentication
model Session {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String    @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// Password reset tokens
model PasswordReset {
  id          String    @id @default(cuid())
  email       String
  token       String    @unique
  expiresAt   DateTime
  used        Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([token])
  @@index([email])
}

// Customer return / exchange requests (one per order)
model ReturnRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reason      String
  details     String?
  requestType String   @default("RETURN") // RETURN or EXCHANGE
  adminNotes  String?
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  pickupFee   Int      @default(0) // ₹99 flat pickup for returns, 0 for exchanges

  // For EXCHANGE requests — desired replacement attributes
  exchangeSize  String?
  exchangeColor String?
  // Set when admin marks the exchange completed and creates a replacement order
  replacementOrderId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Contact messages from customers
model ContactMessage {
  id          String    @id @default(cuid())
  name        String
  email       String
  phone       String?
  subject     String
  message     String
  status      String    @default("NEW") // NEW, READ, REPLIED, CLOSED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}
